{
  "name": "vscode-mosayic",
  "displayName": "Mosayic",
  "description": "Mosayic VS Code Extension",
  "version": "0.0.12",
  "publisher": "mosayic",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "media/icon.png",
  "homepage": "https://app.mosayic.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/mosayic-io/vscode-mosayic.git"
  },
  "bugs": {
    "url": "https://github.com/mosayic-io/vscode-mosayic/issues"
  },
  "keywords": [
    "mosayic",
    "expo",
    "react-native",
    "supabase",
    "mobile"
  ],
  "galleryBanner": {
    "color": "#0b0b0f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "authentication": [
      {
        "id": "mosayic",
        "label": "Mosayic"
      }
    ],
    "commands": [
      {
        "command": "vscode-mosayic.signIn",
        "title": "Mosayic: Sign In"
      },
      {
        "command": "vscode-mosayic.signOut",
        "title": "Mosayic: Sign Out"
      },
      {
        "command": "vscode-mosayic.showOutput",
        "title": "Mosayic: Show Logs"
      },
      {
        "command": "vscode-mosayic.resetCommandPrompts",
        "title": "Mosayic: Reset Command Prompts"
      },
      {
        "command": "vscode-mosayic.switchBackend",
        "title": "Mosayic: Switch Backend\u2026"
      },
      {
        "command": "vscode-mosayic.checkDocker",
        "title": "Mosayic: Check Docker"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vscode-mosayic.switchBackend",
          "when": "config.mosayic.showDevCommands"
        }
      ]
    },
    "configuration": {
      "title": "Mosayic",
      "properties": {
        "mosayic.environment": {
          "type": "string",
          "default": "prod",
          "enum": [
            "prod",
            "dev",
            "custom"
          ],
          "enumDescriptions": [
            "Production backend (default).",
            "Local development backend (http://127.0.0.1:8090).",
            "Use the URL specified in mosayic.apiUrl."
          ],
          "description": "Which Mosayic backend the extension talks to."
        },
        "mosayic.apiUrl": {
          "type": "string",
          "default": "https://mosayic-api-service-336793731775.us-east1.run.app",
          "description": "Custom Mosayic API URL. Only used when mosayic.environment is set to \"custom\"."
        },
        "mosayic.confirmCommands": {
          "type": "string",
          "default": "allowlisted",
          "enum": [
            "allowlisted",
            "always",
            "never"
          ],
          "enumDescriptions": [
            "Auto-approve known Mosayic commands (gh, gcloud, expo, supabase, etc.). Prompt for anything else.",
            "Prompt before every command.",
            "Never prompt. Trust all commands from the Mosayic server."
          ],
          "description": "Controls when to prompt before executing commands from the Mosayic server."
        },
        "mosayic.showDevCommands": {
          "type": "boolean",
          "default": false,
          "description": "Show developer-only commands (e.g. \"Mosayic: Switch Backend\u2026\") in the command palette. For Mosayic contributors."
        },
        "mosayic.windowsShell": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "cmd",
            "gitbash",
            "pwsh"
          ],
          "enumDescriptions": [
            "Use cmd.exe (recommended \u2014 works with all Windows CLI tools and avoids the WSL launcher).",
            "Use cmd.exe.",
            "Use Git Bash from a known install path (never from PATH, which can resolve to the WSL launcher).",
            "Use PowerShell 7 if installed, otherwise Windows PowerShell."
          ],
          "description": "Shell used to run commands on Windows. Ignored on macOS/Linux."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.mjs",
    "package": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint src",
    "pretest": "npm run typecheck && npm run lint"
  },
  "devDependencies": {
    "@types/node": "^22.x",
    "@types/vscode": "^1.96.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
